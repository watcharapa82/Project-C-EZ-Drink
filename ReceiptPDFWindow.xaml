<Window x:Class="EZTicketProject.ReceiptPDFWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True">

    <Border Background="White" CornerRadius="20" Padding="20" Margin="10"
            Effect="{DynamicResource DropShadow}">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="144.583"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Images/close.png"  MouseUp="Image_MouseUp" Style="{StaticResource imgClose}" Margin="0,5,5,0"/>


            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,10" Width="96">
                
                <Border Width="80" Height="80" Background="White" CornerRadius="40" 
                        VerticalAlignment="Center">
                    <Image Source="/Images/Profile.png" Stretch="Uniform"/>
                </Border>

                <TextBlock Text="EZDrink" FontSize="26" FontWeight="Bold"
                           Foreground="#FD8A8A" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" x:Name="ReceiptContainer" Margin="0,0,0,5">

                <TextBlock Text="ใบเสร็จรับเงิน / Receipt" 
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <StackPanel Margin="10,0">

                    <TextBlock Text="{Binding OrderCode, StringFormat='เลขที่ออเดอร์: {0}'}"
                               FontSize="14" Margin="0,4"/>
                    <TextBlock Text="{Binding OrderDate, StringFormat='วันที่สั่งซื้อ: {0}'}"
                               FontSize="14" Margin="0,4"/>

                </StackPanel>

                <Separator Margin="0,10"/>

                <Grid Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="รายการสินค้า" FontWeight="Bold" Grid.Column="0"/>
                    <TextBlock Text="จำนวน" FontWeight="Bold" Grid.Column="1" Margin="20,0"/>
                    <TextBlock Text="ราคา" FontWeight="Bold" Grid.Column="2" Margin="20,0"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding ProductName}" Grid.Column="0"/>
                                <TextBlock Text="{Binding Quantity}" Grid.Column="1" Margin="20,0"/>
                                <TextBlock Text="{Binding Price, StringFormat={}{0:N2}}"
                                           Grid.Column="2" Margin="20,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,10"/>

                <!-- PRICE SUMMARY -->
                <StackPanel Margin="10,0" Height="143">
                    <TextBlock Text="{Binding PriceBeforeVat, StringFormat='ราคาสินค้า: {0:N2} บาท'}" FontSize="14"/>
                    <TextBlock Text="{Binding Vat, StringFormat='VAT 7%: {0:N2} บาท'}" FontSize="14"/>
                    <TextBlock Text="{Binding FinalTotal, StringFormat='ยอดชำระทั้งหมด: {0:N2} บาท'}"
                               FontSize="16" FontWeight="Bold" Foreground="#FD8A8A" Margin="0,10"/>
                </StackPanel>

                <TextBlock Text="สถานะสินค้า: ชำระแล้ว / กำลังดำเนินการจัดส่งสินค้า"
                           Margin="10,20,10,0"/>
            </StackPanel>

            <Button Grid.Row="2" Content="ดาวน์โหลด PDF"
                    Click="BtnSavePDF_Click" Style="{StaticResource mainbutton}"
                    Background="#FD8A8A" Foreground="White"
                    FontWeight="Bold"
                    Margin="120,0,120,0" BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
