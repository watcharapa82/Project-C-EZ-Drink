<Window x:Class="EZTicketProject.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:EZTicketProject"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="RegisterWindow" Height="500" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#FD8A8A" Padding="30" CornerRadius="10 0 0 10">
            <StackPanel VerticalAlignment="Center" Height="401" Margin="-11,0,-10,0">
                <Border BorderBrush="White" BorderThickness="1" CornerRadius="5" Width="96" Height="101">
                    <Image x:Name="imgPreview" Width="90" Stretch="UniformToFill" Margin="2,0,2,1" />
                </Border>
                <Button Content="เลือกรูป" Width="80" Height="30" Margin="10" Background="Black" Foreground="White" Click="BtnSelectImage_Click"/>
                <TextBlock Text="Let's get you sign up" Style="{StaticResource titleText}"  Width="341" Height="57" />
                <TextBlock Text="Please select a role and fill in your information to register." Style="{StaticResource normalText}" Opacity="0.8" />
                <Image x:Name="imgAdmin" Source="/Images/Admin.png" Width="100" Height="100" Margin="0 10 150 0" Cursor="Hand" MouseDown="ImgAdmin_MouseDown"/>
                <Image x:Name="imgUser" Source="/Images/user2.png" Width="100" Height="100" Margin="0 -100 -150 0" Cursor="Hand" MouseDown="ImgUser_MouseDown"/>
            </StackPanel>
        </Border>

        <Image Source="/Images/close.png" Grid.Column="1" Panel.ZIndex="1" MouseUp="Image_MouseUp" Height="30" Width="30" Margin="380,10,10,460"/>
        <Border Background="Transparent" Cursor="Hand" MouseUp="btnBack_MouseUp" Height="40" Width="40" CornerRadius="5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0">
            <Image Source="/Images/Back.png" Height="30" Width="30"/>
        </Border>
        <Image Source="/Images/Thailand.png" Grid.Column="1" Panel.ZIndex="1" Margin="169,263,229,217"/>
        <Image Source="/Images/Sex.png" Grid.Column="1" Panel.ZIndex="1" Margin="83,212,313,266"/>

        <Border Grid.Column="1" Background="White" CornerRadius="0 10 10 0">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Width="336" Margin="0,97,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="168"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Username" Style="{StaticResource normalText2}" Margin="10,12,10,14"/>
                <TextBlock Grid.Row="1" Text="Age" Style="{StaticResource normalText2}" Margin="10,13,10,13"/>
                <TextBlock Grid.Row="1" Text="(You must be 20 or older)" Style="{StaticResource normalText2}" FontSize="10" Opacity="0.5" Margin="43,19,0,17"/>
                <TextBlock Grid.Row="2" Text="Sex" Style="{StaticResource normalText2}" Margin="10,13,10,13"/>
                <TextBlock Grid.Row="3" Text="Phone number" Style="{StaticResource normalText2}" Margin="10,13,163,15" Grid.ColumnSpan="2"/>
                <TextBlock Grid.Row="3" Text="+66" Style="{StaticResource normalText}" FontSize="12" Foreground="Black" Opacity="0.5" Margin="151,17,161,16" Grid.ColumnSpan="2"/>
                <TextBlock Grid.Row="4" Text="Password" Style="{StaticResource normalText2}" Margin="10,15,10,15"/>
                <TextBlock Grid.Row="5" Text="Confirm password" Style="{StaticResource normalText2}" Margin="10,15,10,10"/>

                <TextBox Style="{StaticResource HintStyle}" x:Name="txtName" Grid.Column="1" Grid.Row="0" Tag="Karit" Margin="10,5"  />
                <TextBox Style="{StaticResource HintStyle}" x:Name="txtAge" Grid.Column="1" Grid.Row="1" Tag="20" Margin="10,5"/>
                <TextBox Style="{StaticResource HintStyle}" x:Name="txtSex" Grid.Column="1" Grid.Row="2" Tag="หญิง/ชาย/ไม่ระบุ" Margin="10,5"/>
                <TextBox Style="{StaticResource HintStyle}" x:Name="txtPhone" Grid.Column="1" Grid.Row="3" Tag="08xxxxxxxx" Margin="12,5,8,5"/>

                <PasswordBox x:Name="txtPassword" Grid.Column="1" Grid.Row="4" Margin="10,3,10,7" Style="{StaticResource passwordHintStyle}" Tag="Password"/>
                <PasswordBox x:Name="txtConfirmPassword" Grid.Column="1" Grid.Row="5" Margin="10,5,10,5" Style="{StaticResource passwordHintStyle}" Tag="Confirm password"/>


                <TextBlock Text="สมัครสมาชิก" Style="{StaticResource titleText}" Foreground="Black" Height="50" Margin="-26,-70,-26,70" Grid.ColumnSpan="2"/>
                <TextBlock Text="กรุณากรอกข้อมูลให้ครบถ้วน" Style="{StaticResource normalText}" Opacity="0.5" Foreground="Black" Margin="-26,-31,-26,56" Grid.ColumnSpan="2"/>

                <Button Content="Register" Click="BtnRegister_Click" Style="{StaticResource mainbutton}" Margin="70,16,70,-21" Width="NaN" Grid.ColumnSpan="2" Grid.Row="6"/>

            </Grid>
        </Border>


    </Grid>
</Window>
