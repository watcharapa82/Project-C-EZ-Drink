<Window x:Class="EZTicketProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EZTicketProject"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="MainWindow" Height="500" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/Images/close.png" Grid.Column="1" Panel.ZIndex="1" MouseUp="Image_MouseUp" Style="{StaticResource imgClose}"/>

        <Border CornerRadius="10 0 0 10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFE6E6" Offset="0"/>
                    <GradientStop Color="#FD8A8A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <Image Source="/Images/Profile.png" Width="130" Height="130" Margin="0 0 0 0"/>
                    <TextBlock Text="Sign Up" Style="{StaticResource titleText}" Margin="10"/>
                    <TextBlock Text="Enter your info and create new account to connect us" Style="{StaticResource normalText}" Opacity="0.8" Margin="20 0" />
                    <Button Content="Sign Up" Style="{StaticResource ResourceKey=button}" Margin="10" Click="BtnRegister_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="#FFFFFF" 
            Grid.Column="1" CornerRadius="0 10 10 0" >
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Sign in to App" Style="{StaticResource titleText}" Foreground="#fd8a8a" Margin="10" />

                <Border BorderThickness="1" BorderBrush="#acb0af" CornerRadius="5" Width="400" Margin="20">
                    <Grid Margin="7,0,7,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="/Images/Phone.png" Height="20"/>
                        <TextBlock x:Name="phPhone" MouseDown="phPhone_MouseDown" Text="Phone" Style="{StaticResource textHint}" Grid.Column="1" Margin="10,10,0,9"/>
                        <TextBox x:Name="txtPhone" TextChanged="TxtPhone_TextChanged" Grid.Column="1" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <Border BorderThickness="1" BorderBrush="#acb0af" CornerRadius="5" Width="400" Margin="10" Height="41">
                    <Grid Margin="7 9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="/Images/Log.png" Height="20"/>
                        <TextBlock x:Name="phPassword" MouseDown="phPassword_MouseDown" Text="Password" Style="{StaticResource textHint}" Grid.Column="1" Margin="10,0,0,0"/>
                        <PasswordBox x:Name="txtPassword" PasswordChanged="TxtPassword_PasswordChanged" Grid.Column="1"
                        Margin="10,0,0,0" BorderThickness="0" Background="Transparent" FocusVisualStyle="{x:Null}" />
                    </Grid>
                </Border>
                <Button Content="ลืมรหัสผ่าน?" Foreground="Blue" Background="Transparent" BorderThickness="0" FontSize="12"
                Cursor="Hand" HorizontalAlignment="Center" Click="BtnForgetPassword_Click" />
                <Button Content="Sign In" Click="BtnLogin_Click" Style="{StaticResource mainbutton}" Margin="20"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
