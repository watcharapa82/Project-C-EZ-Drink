<Window x:Class="EZTicketProject.ConfirmOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfirmOrdersWindow" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FFF9F9F9">

    <Grid Margin="18,18,18,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="45.44"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="ยืนยันคำสั่งซื้อ" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" — รายละเอียดคำสั่งซื้อ" VerticalAlignment="Center" Foreground="White" Opacity="0.9" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="161*"/>
                <ColumnDefinition Width="221*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Background="White" CornerRadius="8" Padding="12" Height="205" RenderTransformOrigin="0.5,0.5" Width="306" >
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="0.092"/>
                            <RotateTransform/>
                            <TranslateTransform X="0.198"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <StackPanel Height="288" Margin="-13,0,-12,-107">
                        <TextBlock Text="ข้อมูลผู้สั่ง" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="txtUserName" Text="User: -" Margin="0,5,0,0"/>
                        <TextBlock x:Name="txtPhone" Text="Phone: -" Margin="0,2,0,0"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled" Margin="0,7,0,10" Height="150">

                            <DataGrid x:Name="dgOrders" AutoGenerateColumns="False"
                            SelectionChanged="dgOrders_SelectionChanged"
                            Background="#FFF" RowHeaderWidth="0"
                            AlternatingRowBackground="#FFF6F6" CanUserAddRows="False"
                            IsReadOnly="True" Width="307" Height="149">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ผู้สั่ง" Binding="{Binding UserName}" Width="100"/>
                                    <DataGridTextColumn Header="ราคา" Width="90">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="TotalPrice" StringFormat="{}{0:N2}" />
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="สถานะ" Binding="{Binding Status}" Width="90"/>
                                    <DataGridTextColumn Header="วันที่" Binding="{Binding CreatedAt}" Width="140"/>
                                </DataGrid.Columns>

                            </DataGrid>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                <Border  CornerRadius="8" Padding="12" Height="274" Width="312">
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="รูปสลิปการโอน" FontWeight="Bold" FontSize="14" Height="25" Width="288"/>
                        <Border Height="214" Background="#FFF0F0F0" CornerRadius="6" BorderBrush="#FFE6E6" Width="269">
                            <Image x:Name="imgSlip" Stretch="Uniform"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
            <Border Background="White" CornerRadius="8" Padding="12" Margin="10,0,0,0" Grid.Column="1">
                <StackPanel Margin="-2,-5,0,-12">
                    <TextBlock Text="รายการสินค้า" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <DataGrid x:Name="dgOrderItems" Style="{StaticResource NiceDataGrid}" Height="320" IsReadOnly="True" AutoGenerateColumns="False" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ชื่อสินค้า" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="ราคา/หน่วย" Binding="{Binding Price, StringFormat=N2}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Text" Value="{Binding Price, StringFormat=N2}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="จำนวน" Binding="{Binding Quantity}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="รวม" Binding="{Binding ItemSubtotal, StringFormat=N2}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RightAlignedTextBlock}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Width="382" Height="72">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="ราคาสินค้า :" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtPriceBeforeVat" Text="0.00 บาท" FontSize="14" FontWeight="Bold" Margin="6,0,0,0" Foreground="#444"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <TextBlock Text="Vat 7% :" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtVat" Text="0.00 บาท" FontSize="14" FontWeight="Bold" Margin="6,0,0,0" Foreground="#444"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                            <TextBlock Text="ยอดชำระ :" FontSize="16" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtFinalTotal" Text="0.00 บาท" FontSize="18" FontWeight="ExtraBold" Margin="8,0,0,0" Foreground="#DB3F6C"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="405,0,0,0" Width="285" Height="40" VerticalAlignment="Center">
            <Button Content="ยกเลิกคำสั่งซื้อ" Width="130" Margin="6" Click="BtnReject_Click" Style="{StaticResource CancelButton}"/>
            <Button Content="ยืนยันออเดอร์" Width="130" Margin="6" Click="BtnApprove_Click" Style="{StaticResource RoundedButton}" Background="green"/>
        </StackPanel>
    </Grid>
</Window>