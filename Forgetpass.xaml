<Window x:Class="EZTicketProject.Forgetpass"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EZTicketProject"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="Forgetpass" Height="500" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/Images/close.png" Grid.Column="1" Panel.ZIndex="1" MouseUp="Image_MouseUp" Style="{StaticResource imgClose}"/>

        <Border CornerRadius="10 0 0 10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFE6E6" Offset="0"/>
                    <GradientStop Color="#FD8A8A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <Image Source="/Images/Profile.png" Width="130" Height="130" />
                    <TextBlock Text="Reset Password" Style="{StaticResource titleText}" />
                    <TextBlock Text="Enter your info and create new password to connect us" Style="{StaticResource normalText}" Opacity="0.8" Margin="20 0" />
                </StackPanel>
            </Grid>
        </Border>
        <Border Background="Transparent" Cursor="Hand" MouseUp="btnBack_MouseUp" Height="40" Width="40" CornerRadius="5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0">
            <Image Source="/Images/Back.png" Height="30" Width="30"/>
        </Border>
        <Image Source="/Images/Thailand.png" Grid.Column="1" Panel.ZIndex="1" Margin="169,216,229,264"/>
        
        <Border Grid.Column="1" Background="White" CornerRadius="0 10 10 0">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="336">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="168"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Username" Style="{StaticResource normalText2}" Margin="10,12,10,14"/>
                <TextBlock Grid.Row="1" Text="Phone number" Style="{StaticResource normalText2}" Margin="10,13,163,15" Grid.ColumnSpan="2"/>
                <TextBlock Grid.Row="1" Text="+66" Style="{StaticResource normalText}" FontSize="12" Foreground="Black" Opacity="0.5" Margin="151,17,161,16" Grid.ColumnSpan="2"/>
                <TextBlock Grid.Row="2" Text="Password" Style="{StaticResource normalText2}" Margin="10,15,10,15"/>
                <TextBlock Grid.Row="3" Text="Confirm password" Style="{StaticResource normalText2}" Margin="10,15,10,10"/>

                <TextBox Style="{StaticResource HintStyle}" x:Name="txtUsername" Grid.Column="1" Grid.Row="0" Tag="Karit" Margin="10,5"  />
                <TextBox Style="{StaticResource HintStyle}" x:Name="txtPhone" Grid.Column="1" Grid.Row="1" Tag="08xxxxxxxx" Margin="12,5,8,5"/>

                <PasswordBox x:Name="txtNewPass" Grid.Column="1" Grid.Row="2" Margin="10,3,10,7" Style="{StaticResource passwordHintStyle}" Tag="Password"/>
                <PasswordBox x:Name="txtConfirmPass" Grid.Column="1" Grid.Row="3" Margin="10,5,10,5" Style="{StaticResource passwordHintStyle}" Tag="Confirm password"/>


                <TextBlock Text="รีเซ็ตรหัสผ่าน" Style="{StaticResource titleText}" Foreground="Black" Height="50" Margin="-26,-86,-26,86" Grid.ColumnSpan="2"/>
                <TextBlock Text="กรุณากรอกข้อมูลให้ครบถ้วน" Style="{StaticResource normalText}" Opacity="0.5" Foreground="Black" Margin="-26,-36,-26,61" Grid.ColumnSpan="2"/>

                <Button Content="บันทึกรหัสผ่านใหม่" Click="BtnSave_Click" Style="{StaticResource mainbutton}" Margin="70,69,70,-74" Width="NaN" Grid.ColumnSpan="2" Grid.Row="3"/>

            </Grid>
        </Border>
    </Grid>
</Window>
