<Window x:Class="EZTicketProject.Cart"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EZTicketProject"
        mc:Ignorable="d"
        Title="Cart" Height="500" Width="800" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="30" MouseDown="Bordor_MouseDown" MouseLeftButtonDown="Bordor_MouseLeftButtondown">
        <Grid Margin="-7,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="195"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
            </Grid>
            <Border Background="#FD8A8A" CornerRadius="0 50 0 30" Margin="7,80,0,0">
                <DockPanel>
                    <Border Width="80" Height="80" Padding="3" Background="White" CornerRadius="100" DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="50 -40 0 0">
                        <Ellipse>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Images/Profile.png"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Border>

                    <Separator Margin="20 35" DockPanel.Dock="Top" Height="2" Background="#FFFFFF"/>

                    <Canvas DockPanel.Dock="Top" Height="119">
                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnMain_Click" Height="30" Canvas.Top="-117" Canvas.Left="10" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="HomeVariant" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="หน้าแรก" FontFamily="Tahoma Bold" Width="66"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnCart_Click" Height="30" Canvas.Top="-41" Canvas.Left="9" HorizontalAlignment="Left" VerticalAlignment="Top" Width="153">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="GlassWine" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="ตะกร้าสินค้า" FontFamily="Tahoma Bold" Width="104"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnFavorites_Click" Height="30" Canvas.Left="10" HorizontalAlignment="Left" VerticalAlignment="Top" Width="153" Canvas.Top="-2">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Heart" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="รายการโปรด" FontFamily="Tahoma Bold" Width="104"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnOrganizer_Click" Height="30" Canvas.Top="40" Canvas.Left="9" HorizontalAlignment="Left" VerticalAlignment="Top" Width="153">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="BottleWineOutline" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="จัดการสินค้า" FontFamily="Tahoma Bold" Width="104"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnAdminMenu" Style="{StaticResource ResourceKey=menuButton}" Height="30" Canvas.Top="79" Click="BtnAdminMenu_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Width="146" Canvas.Left="10" >
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Toolbox" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="สำหรับ Admin" FontFamily="Tahoma Bold" Width="93"/>
                            </StackPanel>
                        </Button>

                        <StackPanel x:Name="AdminSubMenuContainer" Background="White" Visibility="Collapsed" Margin="0,0,0,0" HorizontalAlignment="Stretch">
                            <Button Content="Dashboard Member" Click="BtnDashboardMember_Click" Height="40" Margin="10,5,10,0"/>
                            <Button Content="Dashboard Sales" Click="BtnDashboardSales_Click" Height="40" Margin="10,0,10,5"/>
                            <Button Content="Confirm Orders" Click="BtnConfirmOrders_Click" Height="40" Margin="10,-5,10,10"/>
                        </StackPanel>

                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnProfile_Click" Height="30" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Left="9" Width="137" Canvas.Top="-79">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Account" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="ข้อมูลส่วนตัว" FontFamily="Tahoma Bold" Width="83"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnAboutus_Click" Height="30" Canvas.Top="123" Canvas.Left="9" HorizontalAlignment="Left" VerticalAlignment="Top" Width="152">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Creation" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="เกี่ยวกับเรา" FontFamily="Tahoma Bold" Width="104"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ResourceKey=menuButton}" Click="BtnCloss_Click" Height="30" Canvas.Top="167" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Left="8">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Logout" Style="{StaticResource menuButtonIcon}" />
                                <TextBlock Text="ออกจากระบบ" FontFamily="Tahoma Bold" Width="83"/>
                            </StackPanel>
                        </Button>
                    </Canvas>
                </DockPanel>
            </Border>
            <TextBlock Text="EZDrink" Foreground="White" FontSize="22" FontWeight="DemiBold" DockPanel.Dock="Top" TextAlignment="Center" Margin="56,123,55,346"/>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Image Source="/Images/close.png"  MouseUp="Image_MouseUp" Style="{StaticResource imgClose}" Grid.Column="1" Margin="0,13,13,0"/>
                <Border Background="Transparent" Cursor="Hand" MouseUp="btnBack_MouseUp" Height="40" Width="40" CornerRadius="5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-184,9,0,0">
                    <Image Source="/Images/Back.png" Height="30" Width="30" Margin="5,5,5,5"/>
                </Border>
                <TextBlock Grid.Row="0"
               Text="ตะกร้าสินค้า"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#DB3F6C"
               HorizontalAlignment="Center"
               Margin="0,20,0,10"/>

                <DataGrid x:Name="dgCart"
              Grid.Row="1"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              HeadersVisibility="Column"
              ItemsSource="{Binding CartItems}" 
              Margin="10"
              Style="{StaticResource DataGridStyle}" 
              GridLinesVisibility="Horizontal" 
              HorizontalGridLinesBrush="#ccc" 
              Background="White">

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="สินค้า" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProductName}" FontWeight="Bold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="40" MaxWidth="250" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="ราคา (บาท)" Width="Auto"
                        ElementStyle="{StaticResource RightAlignedDataGridCell}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="Price" StringFormat="{}{0:N2}" />
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="จำนวน" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Quantity}" Margin="5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="ราคารวมย่อย (บาท)" Width="Auto"
                        ElementStyle="{StaticResource RightAlignedDataGridCell}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="ItemSubtotal" StringFormat="{}{0:N2}" />
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="ลบ" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="ลบ"
                        Click="BtnRemoveItem_Click"
                        Background="#FF6347" 
                        Foreground="White"
                        BorderThickness="0" 
                        Padding="5,2" Margin="5"
                        FontWeight="SemiBold" 
                        Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Right" Margin="10,0,20,20">
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10" HorizontalAlignment="Right">
                        <TextBlock Text="ยอดสุทธิทั้งหมด: " FontSize="20" FontWeight="Bold" Margin="0,0,10,0"/>

                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N2} บาท}" 
                       FontSize="20" FontWeight="ExtraBold" Foreground="#DB3F6C" />
                    </StackPanel>
                    <Button Content="การชำระเงิน" 
                Click="BtnCheckout_Click" 
                Style="{StaticResource mainbutton}" 
                Width="142" Height="52" 
                Background="#1E90FF" Margin="10"/>
                </StackPanel>
            </Grid>
            
            


        </Grid>
    </Border>
</Window>
