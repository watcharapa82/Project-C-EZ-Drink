<Window x:Class="EZTicketProject.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Checkout" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FFF9F9F9">

    <!-- ===========================
         Resources: styles & brushes
         =========================== -->
    <Window.Resources>
        <!-- สีหลัก -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FD8A8A"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#FFE6E6"/>
        <SolidColorBrush x:Key="AccentText" Color="#DB3F6C"/>

        <!-- ปุ่มมุมมน (ใช้ ControlTemplate) -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- สามารถเพิ่ม Trigger สำหรับ MouseOver / Pressed ได้ตามต้องการ -->
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header style -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ข้อความกึ่งกลาง (ใช้ใน column จำนวน) -->
        <Style x:Key="CenterTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ข้อความชิดขวาสำหรับจำนวนเงิน -->
        <Style x:Key="RightAlignedTextBlock" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- DataGrid ทั่วไป (ปรับ Header style ผ่าน ColumnHeaderStyle) -->
        <Style x:Key="NiceDataGrid" TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF8F8F8"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource DataGridColumnHeaderStyle}"/>
        </Style>
    </Window.Resources>

    <!-- ===========================
         Layout
         =========================== -->
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="ยืนยันคำสั่งซื้อ" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="  — รายละเอียดคำสั่งซื้อ" VerticalAlignment="Center" Foreground="White" Opacity="0.9" Margin="8,0,0,0" Height="14"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,12,-68">
                <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,10" Height="124" Width="293" >
                    <StackPanel Margin="0,0,0,-2">
                        <TextBlock Text="ข้อมูลผู้สั่ง" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="txtOrderInfo" Text="(รายละเอียดผู้สั่งจะแสดงที่นี่)" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="12" Height="368" >
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="รูปสลิปการโอน" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="บัญชีกรุงไทย วัชราภา จำปาโพธิ์ " FontWeight="Bold" FontSize="12"/>
                        <TextBlock Text="เลขที่บัญชี 3410792600 " FontWeight="Bold" FontSize="12"/>
                        <Border Height="232" Background="#FFF0F0F0" CornerRadius="6" BorderBrush="#FFE6E6" BorderThickness="1">
                            <Image x:Name="imgSlip" Stretch="Uniform" Margin="0,0,0,-1" />
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,65,0">
                            <Button Content="อัปโหลดสลิป" Click="BtnUploadSlip_Click" Style="{StaticResource RoundedButton}" Width="140"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,-50">
                <StackPanel Margin="0,0,0,-12">
                    <TextBlock Text="รายการสินค้า" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <DataGrid x:Name="dgItems" Style="{StaticResource NiceDataGrid}" Height="298" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ชื่อสินค้า" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="ราคา/หน่วย" Binding="{Binding Price, StringFormat=N2}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Text" Value="{Binding Price, StringFormat=N2}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="จำนวน" Binding="{Binding Quantity}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="รวม" Binding="{Binding ItemSubtotal, StringFormat=N2}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RightAlignedTextBlock}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- total -->
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Right" Width="331">

                        <!-- ราคาสินค้า (ก่อน VAT) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="ราคาสินค้า :" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtPriceBeforeVat"
                   Text="0.00 บาท"
                   FontSize="14"
                   FontWeight="Bold"
                   Margin="6,0,0,0"
                   Foreground="#444"/>
                        </StackPanel>

                        <!-- Vat 7% -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <TextBlock Text="Vat 7% :" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtVat"
                   Text="0.00 บาท"
                   FontSize="14"
                   FontWeight="Bold"
                   Margin="6,0,0,0"
                   Foreground="#444"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                            <TextBlock Text="ยอดชำระ :" FontSize="16" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTotal"
                   Text="0.00 บาท"
                   FontSize="18"
                   FontWeight="ExtraBold"
                   Margin="8,0,0,0"
                   Foreground="#DB3F6C"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0" Width="360">
            <Button Content="ยกเลิกคำสั่งซื้อ" Width="130" Margin="6" Click="BtnCancelOrder_Click"/>
            <Button Content="ยืนยันการชำระเงิน" Width="130" Margin="6" Click="BtnSubmitOrder_Click" Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </Grid>
</Window>
